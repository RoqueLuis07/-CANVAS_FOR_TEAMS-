# Canvas LMS
CANVAS_BASE_URL=https://usilparaguay.instructure.com
CANVAS_ACCESS_TOKEN=tu_token_de_canvas
CANVAS_ACCOUNT_ID=1

# Supabase (PostgreSQL) — usado para cursos/usuarios/jobs/auditoría
SUPABASE_DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# Azure AD / Microsoft Graph (Teams)
AZURE_TENANT_ID=tu_tenant_id
AZURE_CLIENT_ID=tu_client_id
AZURE_CLIENT_SECRET=tu_client_secret
AZURE_SKU_STUDENTS=STANDARDWOFFPACK_STUDENT
AZURE_SKU_TEACHERS=STANDARDWOFFPACK_FACULTY

# App
PORT=3000
ENVIRONMENT=development
SITE_URL=http://localhost:3000
SECRET_KEY=cambia-esto-por-un-secreto-real
AUTH_COOKIE_NAME=usil_auth

# Institucional
INSTITUTIONAL_DOMAIN=usil.edu.py
USAGE_LOCATION=PY
TEAMS_URL=https://teams.microsoft.com

# Envío de correos de credenciales — vía Microsoft Graph sendMail,
# autenticado con las credenciales de Azure de arriba (requiere el permiso
# de aplicación 'Mail.Send' con consentimiento de administrador en Azure
# Portal). SMTP_FROM es el buzón institucional desde el que se envía.
SMTP_FROM=it@usil.edu.py
